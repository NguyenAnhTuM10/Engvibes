# Database (Spring Boot JDBC format)
DATABASE_URL=jdbc:postgresql://localhost:5433/englishapp
DATABASE_USER=englishapp
DATABASE_PASSWORD=secret

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_VIDEOS=videos
S3_BUCKET_AUDIOS=audios
S3_PUBLIC_URL=http://localhost:9000
S3_REGION=us-east-1
S3_PATH_STYLE=true

# JWT
JWT_SECRET=<random-64-chars-replace-this-before-running>
JWT_EXPIRE_HOURS=24

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Server
SERVER_PORT=8080

# Frontend
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
